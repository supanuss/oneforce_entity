# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Provider Configuration (gemini or local)
LLM_PROVIDER=gemini
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=ollama

LLM_NUM_CTX=8192
LLM_NUM_PREDICT=4096
LLM_RELATION_NUM_PREDICT=2048
LLM_TIMELINE_NUM_PREDICT=1024
RELATION_CONTEXT_MAX_CHARS=3500
TIMELINE_NARRATIVE_CONTEXT_MAX_CHARS=2500
LLM_TIMEOUT=240
LLM_REASONING=false
CASE_LIMIT=10
MAX_RETRY_LIMIT=3

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
KG_ENABLED=true
NEO4J_TIMEOUT=5
NEO4J_MAX_RETRY_TIME=3
KG_MAX_REPAIR_ATTEMPTS=2
